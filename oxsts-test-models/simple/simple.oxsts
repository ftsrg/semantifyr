package semantifyr::verification::simple

@VerificationCase
@Tag("expect-pass")
class Incrementing {
    var x: int := 0

    redefine init {
        x := 1
    }

    redefine tran {
        x := x + 1
    }

    prop {
        return EF x == 10
    }
}

@VerificationCase
@Tag("expect-fail")
class StaysAtOne {
    var x: int := 1

    redefine tran {
        x := 1
    }

    prop {
        return EF x == 0
    }
}

@VerificationCase
@Tag("expect-pass")
class FlipFlopInvariant {
    var state: int := 0

    redefine tran {
        if (state == 0) {
            state := 1
        } else {
            state := 0
        }
    }

    prop {
        return AG (state == 0 || state == 1)
    }
}

@VerificationCase
@Tag("expect-fail")
class CounterExceedsBound {
    var x: int := 0

    redefine tran {
        x := x + 1
    }

    prop {
        return AG x < 5
    }
}
