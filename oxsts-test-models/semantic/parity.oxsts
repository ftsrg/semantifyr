package semantifyr::verification::lang::parity

// Backend parity cases: a minimal, universally-supported subset of the
// language that every production backend (Theta, nuXmv, Spin, Uppaal)
// must be able to verify. Each feature appears with both a reachability
// (EF) and a safety (AG) claim so compilation drift in any backend's
// transform is caught on one side or the other.

// --- integer counter: reachability ---
@VerificationCase
class IntCounterReach {
    var x: int := 0

    redefine tran {
        assume(x < 3)
        x := x + 1
    }

    prop {
        return EF x == 3
    }
}

// --- integer counter: safety bound ---
@VerificationCase
class IntCounterBound {
    var x: int := 0

    redefine tran {
        assume(x < 3)
        x := x + 1
    }

    prop {
        return AG (x >= 0 && x <= 3)
    }
}

// --- boolean havoc: true reachable ---
@VerificationCase
class BoolHavocTrue {
    var flag: bool := false

    redefine tran {
        havoc(flag)
    }

    prop {
        return EF flag == true
    }
}

// --- boolean havoc: false reachable ---
@VerificationCase
class BoolHavocFalse {
    var flag: bool := true

    redefine tran {
        havoc(flag)
    }

    prop {
        return EF flag == false
    }
}

// --- choice + assume: only enumerated branches are reachable ---
@VerificationCase
class ChoiceBound {
    var x: int := 0

    redefine tran {
        choice {
            x := 1
        } or {
            x := 2
        }
    }

    prop {
        return AG (x == 0 || x == 1 || x == 2)
    }
}

// --- choice + assume: each branch is individually reachable ---
@VerificationCase
class ChoiceBranchReach {
    var x: int := 0

    redefine tran {
        choice {
            x := 1
        } or {
            x := 2
        }
    }

    prop {
        return EF x == 2
    }
}
