package semantifyr::verification::lang::property_calls

// Property calls: inline-expansion of named properties into the main
// property expression at compile time. Tests cover self-calls, calls
// via self-navigation, and calls through a single-level navigation.

// --- bare self-call ---

// Reachable: isPositive() returns true once x > 0.
@VerificationCase
class PropSelfBareCallReach {
    var x: int := 0

    prop isPositive(): bool {
        return x > 0
    }

    redefine tran {
        assume(x < 3)
        x := x + 1
    }

    prop {
        return EF isPositive()
    }
}

// Dual: !isPositive() is the invariant when x stays zero (captures
// the initial state where the inlined body evaluates to false).
@VerificationCase
class PropSelfBareCallInitialState {
    var x: int := 0

    prop isZero(): bool {
        return x == 0
    }

    redefine tran { }

    prop {
        return AG isZero()
    }
}

// --- self-call via explicit self-navigation ---

@VerificationCase
class PropSelfNavCallReach {
    var x: int := 0

    prop isPositive(): bool {
        return x > 0
    }

    redefine tran {
        assume(x < 3)
        x := x + 1
    }

    prop {
        return EF self.isPositive()
    }
}

// --- single-level navigation call ---

class PropWorker {
    var done: bool := false
    prop isDone(): bool {
        return done
    }
}

@VerificationCase
class PropNavigationCallReach {
    contains w: PropWorker[1]

    redefine tran {
        w.done := true
    }

    prop {
        return EF w.isDone()
    }
}

// Dual: before the transition fires, w.isDone() is false.
@VerificationCase
class PropNavigationCallInitialState {
    contains w: PropWorker[1]

    redefine tran { }

    prop {
        return AG !w.isDone()
    }
}
