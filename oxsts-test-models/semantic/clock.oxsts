package semantifyr::verification::lang::clock

@VerificationCase
@Tag("expect-pass")
class ClockResetInvariant {
    @Clock
    var t: int

    redefine init {
        t := 0
    }

    redefine tran {
        t := t + 1
    }

    prop {
        return AG t >= 0
    }
}

@VerificationCase
@Tag("expect-pass")
class ClockReach100 {
    @Clock
    var t: int

    redefine init {
        t := 0
    }

    redefine tran {
        t := t + 1
    }

    prop {
        return EF t == 100
    }
}
