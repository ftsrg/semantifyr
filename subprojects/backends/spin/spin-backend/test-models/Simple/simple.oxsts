package semantifyr::spin::simple

// Spin is an explicit-state model checker: strong at bounded,
// finite-state reachability and cycle detection. Cases here stay
// bounded so the state space is tractable. Unbounded-int inductive
// proofs are NOT Spin's strength - those belong in Theta / nuXmv IC3
// suites.

// --- bounded integer counter: reachability ---

@VerificationCase
@Tag("expect-pass")
class Incrementing {
    var x: int := 0

    redefine init {
        x := 1
    }

    redefine tran {
        x := x + 1
    }

    prop {
        return EF x == 10
    }
}

// --- bounded flip-flop invariant (finite reachable set) ---

@VerificationCase
@Tag("expect-pass")
class Invariant {
    var state: int := 0

    redefine tran {
        if (state == 0) {
            state := 1
        } else {
            state := 0
        }
    }

    prop {
        return AG (state == 0 || state == 1)
    }
}

// --- boolean havoc: both polarities reachable ---

@VerificationCase
@Tag("expect-pass")
class BoolHavocReachesTrue {
    var flag: bool := false

    redefine tran {
        havoc(flag)
    }

    prop {
        return EF flag == true
    }
}

@VerificationCase
@Tag("expect-pass")
class BoolHavocReachesFalse {
    var flag: bool := true

    redefine tran {
        havoc(flag)
    }

    prop {
        return EF flag == false
    }
}

// --- nondeterministic choice: each branch reachable, output bounded ---

@VerificationCase
@Tag("expect-pass")
class ChoiceReachesBranch1 {
    var x: int := 0

    redefine tran {
        choice {
            x := 1
        } or {
            x := 2
        }
    }

    prop {
        return EF x == 1
    }
}

@VerificationCase
@Tag("expect-pass")
class ChoiceReachesBranch2 {
    var x: int := 0

    redefine tran {
        choice {
            x := 1
        } or {
            x := 2
        }
    }

    prop {
        return EF x == 2
    }
}

// --- expect-fail: reachability claim invalidated by the model ---

@VerificationCase
@Tag("expect-fail")
class StaysAtOne {
    var x: int := 1

    redefine tran {
        x := 1
    }

    prop {
        return EF x == 0
    }
}

@VerificationCase
@Tag("expect-fail")
class CounterExceedsBound {
    var x: int := 0

    redefine tran {
        x := x + 1
    }

    prop {
        return AG x < 5
    }
}
