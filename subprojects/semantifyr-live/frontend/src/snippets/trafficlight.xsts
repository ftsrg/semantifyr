
type LightColor : {
	Red, Yellow, Green
}
var $$root$$light$$color: LightColor = LightColor.Red
trans {
	choice {
		assume $$root$$light$$color == LightColor.Red;
		$$root$$light$$color := LightColor.Green;
	} or {
		assume $$root$$light$$color == LightColor.Green;
		$$root$$light$$color := LightColor.Yellow;
	} or {
		assume $$root$$light$$color == LightColor.Yellow;
		$$root$$light$$color := LightColor.Red;
	}
}
init {
}
env {
}
prop {
	!( $$root$$light$$color == LightColor.Green )
}
