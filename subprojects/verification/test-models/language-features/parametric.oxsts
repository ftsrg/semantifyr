package semantifyr::verification::lang::parametric

// Parametric transition - arguments are substituted into the body on inline.
@VerificationCase
class ParametricTran {
    var x: int := 0

    tran addN(n: int) {
        x := x + n
    }

    redefine tran {
        inline addN(3)
    }

    prop {
        return EF (x == 9)
    }
}

// Parametric property - arguments are substituted into the body on inline.
@VerificationCase
class ParametricProp {
    var x: int := 0

    prop equals(n: int): bool {
        return x == n
    }

    redefine tran {
        x := x + 1
    }

    prop {
        return EF equals(5)
    }
}

// Parametric transition with an enum argument.
enum Level {
    Low,
    High
}

@VerificationCase
class ParametricEnumTran {
    var level: Level := Level::Low

    tran setLevel(l: Level) {
        level := l
    }

    redefine tran {
        inline setLevel(Level::High)
    }

    prop {
        return EF (level == Level::High)
    }
}
