package semantifyr::verification::lang::variable_dispatch

class DispatchWorker {
    var done: bool := false
    tran step() {
        done := true
    }
}

// Variable dispatching: `current` holds either `a` or `b`; inlining fans
// out across both candidates via a choice with an equality assumption.
// The prop holds because every trace that sets `current` to `a` sets
// `a.done`, and similarly for `b`.
@VerificationCase
class VariableDispatch {
    contains workers: DispatchWorker[0..*]
    contains a: DispatchWorker[1] subsets workers
    contains b: DispatchWorker[1] subsets workers

    var current: workers[0..1] := nothing

    redefine init {
        choice {
            current := a
        } or {
            current := b
        }
    }

    redefine tran {
        inline current.step()
    }

    prop {
        return EF (a.done || b.done)
    }
}
