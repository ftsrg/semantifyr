package semantifyr::verification::lang::primitives

// Integer counter reaches a target value via repeated increment.
@VerificationCase
class IntegerCounter {
    var x: int := 0

    redefine tran {
        x := x + 1
    }

    prop {
        return EF x == 10
    }
}

// Boolean variable flips to true through a havoc branch.
@VerificationCase
class BooleanHavoc {
    var b: bool := false

    redefine tran {
        havoc(b)
    }

    prop {
        return EF b == true
    }
}

// Bounded decrement - property holds because we stop at zero.
@VerificationCase
class BoundedDecrement {
    var x: int := 5

    redefine tran {
        choice {
            assume(x > 0)
            x := x - 1
        } or {
            assume(x == 0)
        }
    }

    prop {
        return AG (x >= 0 && x <= 5)
    }
}
