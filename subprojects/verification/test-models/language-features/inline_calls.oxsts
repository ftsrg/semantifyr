package semantifyr::verification::lang::inline_calls

// Bare self-call: `inline step()` invokes the same class's named transition.
@VerificationCase
class SelfBareCall {
    var x: int := 0

    tran step() {
        x := x + 1
    }

    redefine tran {
        inline step()
    }

    prop {
        return EF x == 3
    }
}

// Self-call via explicit self navigation.
@VerificationCase
class SelfNavCall {
    var x: int := 0

    tran step() {
        x := x + 1
    }

    redefine tran {
        inline self.step()
    }

    prop {
        return EF x == 3
    }
}

// Call through a single-level containment navigation.
class LocalWorker {
    var done: bool := false
    tran finish() {
        done := true
    }
}

@VerificationCase
class SingleNavigationCall {
    contains w: LocalWorker[1]

    redefine tran {
        inline w.finish()
    }

    prop {
        return EF w.done == true
    }
}

// Call through multi-level containment: mid.leaf.bump().
class LeafBump {
    var v: int := 0
    tran bump() {
        v := v + 1
    }
}

class MidHolder {
    contains leaf: LeafBump[1]
}

@VerificationCase
class MultiNavigationCall {
    contains mid: MidHolder[1]

    redefine tran {
        inline mid.leaf.bump()
    }

    prop {
        return EF mid.leaf.v == 3
    }
}
