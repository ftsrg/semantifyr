package semantifyr::verification::lang::temporal

// EF - reachability of a target state.
@VerificationCase
class TemporalEF {
    var x: int := 0

    redefine tran {
        x := x + 1
    }

    prop {
        return EF (x == 5)
    }
}

// AG - every reachable state satisfies the invariant.
@VerificationCase
class TemporalAG {
    var x: int := 0

    redefine tran {
        x := 1 - x
    }

    prop {
        return AG (x >= 0 && x <= 1)
    }
}

// AG combined with a disjunction - exercises boolean connectives in the prop.
@VerificationCase
class TemporalDisjunction {
    var x: int := 0

    redefine tran {
        choice {
            x := 1
        } or {
            x := 2
        } or {
            x := 3
        }
    }

    prop {
        return AG (x == 0 || x == 1 || x == 2 || x == 3)
    }
}

// Nested EF-AG - there is a reachable state from which the invariant holds forever.
@VerificationCase
class TemporalEFAG {
    var x: int := 0

    redefine tran {
        choice {
            assume(x < 3)
            x := x + 1
        } or {
            assume(x == 3)
        }
    }

    prop {
        return EF (AG (x == 3))
    }
}
