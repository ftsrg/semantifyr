package semantifyr::verification::lang::local_vars

// Local variable scoped to a transition. `sum` aggregates into a local,
// then writes out to a class-level variable.
@VerificationCase
class LocalVarAccumulate {
    var total: int := 0

    redefine tran {
        var part: int := 0
        part := part + 1
        part := part + 2
        total := total + part
    }

    prop {
        return EF (total == 3)
    }
}

// Local variable takes a havoc'd value; the surrounding assume narrows it.
@VerificationCase
class LocalVarHavoc {
    var x: int := 0

    redefine tran {
        var delta: int := 0
        havoc(delta)
        assume(delta >= 1 && delta <= 3)
        x := x + delta
    }

    prop {
        return EF (x >= 1 && x <= 3)
    }
}
