{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "types": ["node", "@docusaurus/module-type-aliases", "@docusaurus/theme-classic"],
    "noEmit": true,
    "paths": { "@site/*": ["./*"] }
  },
  "include": ["src", "docusaurus.config.ts", "sidebars.ts"],
  "exclude": [".docusaurus", "node_modules", "build", "static-imported-branding"]
}
