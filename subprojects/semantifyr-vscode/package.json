{
  "name": "semantifyr",
  "displayName": "Semantifyr",
  "description": "Language support and verification tooling for Semantifyr. Semantic library-driven formal verification of engineering models.",
  "version": "0.0.1",
  "type": "module",
  "publisher": "ftsrg",
  "license": "EPL-2.0",
  "author": {
    "name": "The Semantifyr Authors",
    "url": "https://github.com/ftsrg/semantifyr/blob/main/CONTRIBUTORS.md"
  },
  "homepage": "https://ftsrg.mit.bme.hu/semantifyr/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ftsrg/semantifyr.git",
    "directory": "subprojects/semantifyr-vscode"
  },
  "bugs": {
    "url": "https://github.com/ftsrg/semantifyr/issues"
  },
  "icon": "icons/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Testing"
  ],
  "keywords": [
    "semantifyr",
    "oxsts",
    "xsts",
    "gamma",
    "formal verification",
    "model checking",
    "theta",
    "language server"
  ],
  "files": [
    "dist/extension.cjs",
    "bin",
    "syntaxes/*.json",
    "language-configuration.json",
    "icons/icon.png",
    "icons/semantifyr-file-icon.png",
    "icons/gamma-file-icon.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "semantifyr.verifyXsts",
        "title": "Verify XSTS File",
        "category": "Semantifyr"
      },
      {
        "command": "gamma.compile",
        "title": "Compile Gamma File",
        "category": "Semantifyr"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "semantifyr.verifyXsts",
          "when": "resourceExtname == .xsts",
          "group": "semantifyr"
        },
        {
          "command": "gamma.compile",
          "when": "resourceExtname == .gamma",
          "group": "semantifyr"
        }
      ]
    },
    "languages": [
      {
        "id": "oxsts",
        "extensions": [
          ".oxsts"
        ],
        "aliases": [
          "OXSTS",
          "oxsts"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/semantifyr-file-icon.png",
          "dark": "./icons/semantifyr-file-icon.png"
        }
      },
      {
        "id": "xsts",
        "extensions": [
          ".xsts"
        ],
        "aliases": [
          "XSTS",
          "xsts"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/semantifyr-file-icon.png",
          "dark": "./icons/semantifyr-file-icon.png"
        }
      },
      {
        "id": "gamma",
        "extensions": [
          ".gamma"
        ],
        "aliases": [
          "Gamma",
          "gamma"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/gamma-file-icon.png",
          "dark": "./icons/gamma-file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "oxsts",
        "scopeName": "source.oxsts",
        "path": "./syntaxes/oxsts.tmLanguage.json"
      },
      {
        "language": "xsts",
        "scopeName": "source.xsts",
        "path": "./syntaxes/xsts.tmLanguage.json"
      },
      {
        "language": "gamma",
        "scopeName": "source.gamma",
        "path": "./syntaxes/gamma.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "lint": "eslint",
    "check": "npm run typecheck && npm run lint",
    "assemble": "node esbuild.mjs",
    "assemble:watch": "node esbuild.mjs --watch",
    "assemble:production": "node esbuild.mjs --minify",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run check && npm run assemble",
    "build:production": "npm run check && npm run assemble:production",
    "watch:all": "concurrently -k \"npm run typecheck:watch\" \"npm run assemble:watch\"",
    "bundle": "npm run build:production && vsce package --out build/"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.1",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.24.1",
    "@vscode/vsce": "^3.2.2"
  }
}
