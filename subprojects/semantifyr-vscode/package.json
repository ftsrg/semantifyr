{
  "name": "semantifyr",
  "displayName": "Semantifyr",
  "description": "Language support and verification tooling for Semantifyr. Semantic library-driven formal verification of engineering models.",
  "version": "0.1.0",
  "type": "module",
  "publisher": "ftsrg",
  "license": "EPL-2.0",
  "author": {
    "name": "The Semantifyr Authors",
    "url": "https://github.com/ftsrg/semantifyr/blob/main/CONTRIBUTORS.md"
  },
  "homepage": "https://ftsrg.mit.bme.hu/semantifyr/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ftsrg/semantifyr.git",
    "directory": "subprojects/semantifyr-vscode"
  },
  "bugs": {
    "url": "https://github.com/ftsrg/semantifyr/issues"
  },
  "icon": "icons/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Testing"
  ],
  "keywords": [
    "semantifyr",
    "oxsts",
    "gamma",
    "formal verification",
    "model checking",
    "theta",
    "language server"
  ],
  "files": [
    "dist/extension.cjs",
    "bin",
    "syntaxes/*.json",
    "language-configuration.json",
    "icons/icon.png",
    "icons/semantifyr-file-icon.png",
    "icons/gamma-file-icon.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "semantifyr.gamma.compile",
        "title": "Compile Gamma File",
        "category": "Semantifyr"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "semantifyr.gamma.compile",
          "when": "resourceExtname == .gamma",
          "group": "semantifyr"
        }
      ]
    },
    "languages": [
      {
        "id": "oxsts",
        "extensions": [
          ".oxsts"
        ],
        "aliases": [
          "OXSTS",
          "oxsts"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/semantifyr-file-icon.png",
          "dark": "./icons/semantifyr-file-icon.png"
        }
      },
      {
        "id": "gamma",
        "extensions": [
          ".gamma"
        ],
        "aliases": [
          "Gamma",
          "gamma"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/gamma-file-icon.png",
          "dark": "./icons/gamma-file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "oxsts",
        "scopeName": "source.oxsts",
        "path": "./syntaxes/oxsts.tmLanguage.json"
      },
      {
        "language": "gamma",
        "scopeName": "source.gamma",
        "path": "./syntaxes/gamma.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Semantifyr",
      "properties": {
        "semantifyr.portfolio": {
          "type": "string",
          "default": "theta-full",
          "enum": [
            "smart-full",
            "all-agree-full",
            "theta-full",
            "theta-cegar-expl",
            "theta-cegar-expl-pred-combined",
            "theta-cegar-pred-cart",
            "theta-bounded-kinduction",
            "theta-bounded-bmc",
            "theta-bounded-imc",
            "theta-ic3",
            "uppaal-default",
            "uppaal-breadth-first",
            "uppaal-depth-first",
            "uppaal-random-depth-first",
            "uppaal-over-approximation",
            "uppaal-under-approximation",
            "uppaal-under-approximation-large",
            "uppaal-aggressive-inclusion",
            "nuxmv-ic3-invar",
            "nuxmv-bmc-invar",
            "nuxmv-bdd-invar",
            "spin-exhaustive-dfs",
            "spin-exhaustive-bfs",
            "spin-safe-dfs",
            "spin-fast-dfs",
            "spin-collapse",
            "spin-bitstate",
            "spin-hash-compact"
          ],
          "markdownDescription": "Backend portfolio used when running verification. `smart-full` is the recommended general-purpose pick; `all-agree-full` is the cross-backend cross-check used by witness validation. The remaining entries pin one backend / configuration."
        },
        "semantifyr.timeoutSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 1,
          "markdownDescription": "Per-case wall-clock timeout, in seconds."
        },
        "semantifyr.maxConcurrency": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "Maximum number of concurrent backend runs. `0` lets the server decide (defaults to available processor count)."
        },
        "semantifyr.theta.executor": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "shell", "docker"],
          "markdownDescription": "Which Theta executor to use. `auto` picks shell first then Docker; `shell` requires `theta-xsts-cli` on PATH; `docker` uses the configured image."
        },
        "semantifyr.theta.dockerImage": {
          "type": "string",
          "default": "ftsrg/theta-xsts-cli:6.28.1",
          "markdownDescription": "Docker image reference (repository:tag or @digest) for the Theta image. Only used when `semantifyr.theta.executor` is `docker`."
        },
        "semantifyr.artifacts.location": {
          "type": "string",
          "default": "temporary",
          "enum": ["temporary", "directory"],
          "markdownDescription": "Where to retain compiled/generated artifacts. `temporary`: a short-lived temp directory cleaned on exit; `directory`: write under `semantifyr.artifacts.directory`."
        },
        "semantifyr.artifacts.directory": {
          "type": "string",
          "default": "",
          "markdownDescription": "Directory that receives artifacts when `semantifyr.artifacts.location` is `directory`. Leave empty to fall back to a temporary directory."
        },
        "semantifyr.artifacts.preset": {
          "type": "string",
          "default": "all",
          "enum": ["none", "all", "debug"],
          "markdownDescription": "Artifact preset. `none` disables artifact emission, `all` writes the usual artifacts (models, witness, trace, mapping, report), `debug` additionally writes per-pass step dumps (slow; only for bisecting compiler regressions)."
        },
        "semantifyr.optimization.level": {
          "type": "string",
          "default": "all",
          "enum": ["none", "all"],
          "markdownDescription": "Compiler optimization preset. `none` disables all passes; `all` enables the default bundle."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "lint": "eslint",
    "check": "npm run typecheck && npm run lint",
    "assemble": "node esbuild.mjs",
    "assemble:watch": "node esbuild.mjs --watch",
    "assemble:production": "node esbuild.mjs --minify",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run check && npm run assemble",
    "build:production": "npm run check && npm run assemble:production",
    "watch:all": "concurrently -k \"npm run typecheck:watch\" \"npm run assemble:watch\"",
    "bundle": "npm run build:production && vsce package --no-dependencies --out build/"
  },
  "dependencies": {
    "@semantifyr/editor-common": "*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.1",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.24.1"
  }
}
